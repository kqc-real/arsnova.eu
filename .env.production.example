# -----------------------------------------------------------------------------
# arsnova.eu – Produktion (docker-compose.prod.yml)
# Kopiere zu .env.production und setze starke Passwörter/Secrets.
# Diese Datei nicht mit echten Secrets füllen – nur als Vorlage.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Credentials / Secrets (zuerst setzen)
# -----------------------------------------------------------------------------
POSTGRES_USER=arsnova_user
POSTGRES_PASSWORD=<starkes-Passwort-setzen>
POSTGRES_DB=arsnova_v3
DATABASE_URL="postgresql://arsnova_user:<starkes-Passwort>@postgres:5432/arsnova_v3?schema=public"
REDIS_URL="redis://redis:6379"
# Erzeugen mit: openssl rand -base64 32
JWT_SECRET=<starker-zufälliger-Schlüssel>
# Erzeugen mit: openssl rand -base64 48
ADMIN_SECRET=<starker-admin-schlüssel>

# -----------------------------------------------------------------------------
# Laufzeit / Netzwerk
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
WS_PORT=3001
YJS_WS_PORT=3002
# In Docker hinter Nginx meist 0.0.0.0 korrekt:
YJS_WS_HOST=0.0.0.0
# Hinter genau einem Reverse-Proxy (z. B. Nginx) fast immer notwendig:
TRUST_PROXY_HOPS=1

# -----------------------------------------------------------------------------
# Admin-Konfiguration
# -----------------------------------------------------------------------------
ADMIN_SESSION_TTL_SECONDS=28800
ADMIN_LEGAL_HOLD_DEFAULT_DAYS=30

# -----------------------------------------------------------------------------
# Rate Limits (hochfrequentierter Produktivbetrieb, pro IP)
# -----------------------------------------------------------------------------
# Session-Code-Eingabe: fuer große Shared-NAT-Netze bewusst weniger strikt.
RATE_LIMIT_SESSION_CODE_ATTEMPTS=20
RATE_LIMIT_SESSION_CODE_WINDOW_MINUTES=5
RATE_LIMIT_SESSION_CODE_LOCKOUT_SECONDS=45

# Vote-Submit pro Teilnehmer-ID (nicht pro IP): leicht erhöht fuer Retry-Spitzen.
RATE_LIMIT_VOTE_REQUESTS_PER_SECOND=2

# Session-Starts pro Stunde: hoher Wert fuer viele Einrichtungen hinter NAT.
RATE_LIMIT_SESSION_CREATE_PER_HOUR=480
RATE_LIMIT_SESSION_CREATE_BYPASS_LOCALHOST=false

# MOTD (Epic 10)
RATE_LIMIT_MOTD_GET_CURRENT_PER_MINUTE=1200
RATE_LIMIT_MOTD_GET_CURRENT_BYPASS_LOCALHOST=false
RATE_LIMIT_MOTD_LIST_ARCHIVE_PER_MINUTE=180
RATE_LIMIT_MOTD_RECORD_INTERACTION_PER_MINUTE=120
