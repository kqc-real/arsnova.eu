// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Das Meta-Dokument für den Server (Session-Kopie beim Quiz-Upload, Story 2.1a).
// Kein creatorId/User – die App ist accountfrei (Zero-Account, Local-First).
model Quiz {
  id                   String     @id @default(uuid())
  historyScopeId       String?    @db.Uuid // Stabile Quiz-Identität über mehrere Upload-Kopien hinweg
  name                 String
  description          String?
  motifImageUrl        String?    // HTTPS-URL, optionales Motivbild (Host, Quiz-Kanal)
  showLeaderboard      Boolean    @default(true)   // Story 1.4: Leaderboard an/aus
  allowCustomNicknames Boolean    @default(true)   // Story 1.4: Eigene Pseudonyme erlauben
  defaultTimer         Int?                         // Story 1.4: Standard-Countdown in Sekunden
  timerScaleByDifficulty Boolean  @default(true)   // Story 1.4: Timer nach EASY/MEDIUM/HARD skalieren
  enableSoundEffects   Boolean    @default(true)   // Story 5.1: Sound-Effekte an/aus
  enableRewardEffects  Boolean    @default(true)   // Story 5.4: Belohnungseffekte an/aus
  enableMotivationMessages Boolean @default(true) // Story 5.7: Motivationsmeldungen an/aus
  enableEmojiReactions Boolean    @default(true)   // Story 5.8: Emoji-Reaktionen an/aus
  anonymousMode        Boolean    @default(false)  // Story 3.6: Anonymer Modus (keine Nicknames)
  teamMode             Boolean    @default(false)  // Story 7.1: Team-Modus an/aus
  teamCount            Int?                         // Story 7.1: Anzahl Teams (2–8, null = kein Team-Modus)
  teamAssignment       TeamAssignment @default(AUTO) // Story 7.1: Teamzuweisung
  teamNames            String[]   @default([])       // Story 7.1b: Konfigurierbare Team-Namen
  backgroundMusic      String?                      // Story 5.3: Track-Name (null = aus)
  nicknameTheme        NicknameTheme @default(NOBEL_LAUREATES) // Story 3.2: Nickname-Liste
  bonusTokenCount      Int?                         // Story 4.6: Anzahl Top-Plätze mit Bonus-Token (1–50, null = deaktiviert)
  readingPhaseEnabled  Boolean    @default(true)   // Story 2.6: Zwei-Phasen-Frageanzeige (Lesephase vor Antworten)
  preset               String     @default("PLAYFUL") // PLAYFUL oder SERIOUS – visuelles Theme für alle Clients
  questions            Question[]
  sessions             Session[]
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([historyScopeId])
}

// Eine einzelne Frage
model Question {
  id         String         @id @default(uuid())
  text       String
  type       QuestionType
  timer      Int?           // Optionaler Countdown in Sekunden (überschreibt Quiz.defaultTimer)
  difficulty Difficulty     @default(MEDIUM) // Schwierigkeitsgrad für Punkteberechnung
  skipReadingPhase Boolean  @default(false) // Story 2.6a: Frage überspringt die globale Lesephase
  ratingMin  Int?           // Story 1.2c: Untere Skalengrenze (nur bei RATING, default: 1)
  ratingMax  Int?           // Story 1.2c: Obere Skalengrenze (nur bei RATING, default: 5)
  ratingLabelMin String?    // Story 1.2c: Label für Minimum (z.B. "Stimme gar nicht zu")
  ratingLabelMax String?    // Story 1.2c: Label für Maximum (z.B. "Stimme voll zu")
  quizId     String
  quiz       Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers    AnswerOption[]
  votes      Vote[]
  order      Int            // Sortierung

  @@index([quizId, order])
}

// Die Antwortmöglichkeiten
model AnswerOption {
  id         String   @id @default(uuid())
  text       String
  isCorrect  Boolean  // WICHTIG: Darf im Live-Quiz niemals an Studenten geleakt werden!
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  voteAnswers VoteAnswer[] // MC: mehrere Votes pro Option möglich
}

// ─── Live-Session (Story 2.1–2.3) ───────────────────────────────────────────

// Eine gestartete Quiz-Sitzung mit 6-stelligem Code
model Session {
  id              String        @id @default(uuid())
  code            String        @unique // 6-stelliger Beitrittscode
  type            SessionType   @default(QUIZ)    // Story 8.1: Quiz oder Q&A
  status          SessionStatus @default(LOBBY)
  statusChangedAt DateTime      @default(now())    // Zeitpunkt des letzten Statuswechsels (Story 3.5 Countdown-Sync)
  title           String?                          // Story 8.1: Titel für Q&A-Runden
  moderationMode  Boolean       @default(false)   // Story 8.4: Q&A-Fragen vorab moderieren
  qaEnabled       Boolean       @default(false)   // ADR-0009: Q&A-Kanal innerhalb einer Live-Session
  qaOpen          Boolean       @default(false)   // ADR-0009: Q&A-Kanal aktuell für Teilnehmende geöffnet
  qaTitle         String?                          // ADR-0009: Titel des Q&A-Kanals
  qaModerationMode Boolean      @default(true)    // ADR-0009: Vorab-Moderation für Q&A-Kanal (Default: an)
  quickFeedbackEnabled Boolean  @default(false)   // ADR-0009: Blitz-Feedback-Kanal innerhalb einer Session
  quickFeedbackOpen Boolean     @default(false)   // ADR-0009: Blitz-Feedback-Kanal aktuell für Teilnehmende geöffnet
  onboardingProfileConfigured Boolean @default(false) // Session-weites Onboarding-Profil aktiv
  onboardingAllowCustomNicknames Boolean?
  onboardingAnonymousMode Boolean?
  onboardingTeamMode Boolean?
  onboardingTeamCount Int?
  onboardingTeamAssignment TeamAssignment?
  onboardingTeamNames String[]  @default([])
  onboardingNicknameTheme NicknameTheme?
  currentQuestion Int?                             // Index der aktuell aktiven Frage (0-basiert)
  currentRound    Int              @default(1)     // Story 2.7: Peer Instruction – aktuelle Abstimmungsrunde (1 oder 2)
  quizId          String?                          // null bei Q&A-Sessions
  quiz            Quiz?         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  participants    Participant[]
  teams           Team[]
  votes           Vote[]
  bonusTokens     BonusToken[]  // Story 4.6: Bonus-Tokens für Top-Platzierungen
  sessionFeedbacks SessionFeedback[] // Story 4.8: Session-Bewertungen
  qaQuestions     QaQuestion[]  // Story 8: Q&A-Fragen
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  legalHoldUntil  DateTime?                         // Epic 9: schützt vor Purge bis Zeitpunkt
  legalHoldReason String?                           // Epic 9: Begründung für Legal Hold
  legalHoldSetAt  DateTime?                         // Epic 9: Zeitpunkt des letzten Hold-Setzens
  /// Pro Session gemischte Anzeige-Reihenfolge der Antwortoptionen: { [questionId]: answerOptionId[] } (einmal bei erster Frage)
  answerDisplayOrder Json?

  @@index([status, startedAt, id])
  @@index([status, endedAt])
  @@index([legalHoldUntil])
}

// Ein Teilnehmer in einer Live-Session (Story 3.1, 3.2)
model Participant {
  id        String   @id @default(uuid())
  nickname  String
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  teamId    String?                                  // Story 7.1: Team-Zugehörigkeit (optional)
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  votes      Vote[]
  bonusTokens BonusToken[] // Story 4.6: Ausgestellte Bonus-Tokens
  sessionFeedbacks SessionFeedback[] // Story 4.8: Bewertungen
  qaQuestions QaQuestion[] // Story 8.2: Eingereichte Q&A-Fragen
  qaUpvotes  QaUpvote[]   // Story 8.3: Q&A-Upvotes
  joinedAt   DateTime @default(now())

  @@unique([sessionId, nickname]) // Kein doppelter Nickname pro Session
}

// Singleton-Zeile: plattformweite Kennzahlen (höchste Teilnehmerzahl je Session)
model PlatformStatistic {
  id                          String @id // fest: "default"
  maxParticipantsSingleSession Int   @default(0)
  completedSessionsTotal      Int   @default(0) // Monotone Gesamtzahl beendeter Sessions (für health.stats)
  updatedAt                   DateTime @updatedAt
}

// Ein Team in einer Live-Session (Story 7.1)
model Team {
  id           String        @id @default(uuid())
  name         String                                // z.B. "Team A", "Team Blau"
  color        String?                               // Optionale Farbcodierung (Hex)
  sessionId    String
  session      Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participants Participant[]

  @@unique([sessionId, name]) // Kein doppelter Teamname pro Session
}

// Eine abgegebene Stimme (Story 3.3)
model Vote {
  id             String       @id @default(uuid())
  sessionId      String
  session        Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participantId  String
  participant    Participant  @relation(fields: [participantId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedAnswers VoteAnswer[] // MC: mehrere, SC: genau eine, FREETEXT/RATING: keine
  freeText       String?      // Freitext-Antwort (nur bei QuestionType.FREETEXT)
  ratingValue    Int?         // Story 1.2c: Gewählter Skalenwert (nur bei QuestionType.RATING)
  responseTimeMs Int?         // Antwortzeit in Millisekunden (für Zeitbonus)
  score          Int          @default(0) // Berechnete Punkte (Schwierigkeit × Zeitbonus)
  streakCount    Int          @default(0) // Story 5.5: Aktuelle Antwort-Serie (0 = kein Streak)
  streakBonus    Float        @default(1.0) // Story 5.5: Angewandter Streak-Multiplikator
  round          Int          @default(1) // Story 2.7: Peer Instruction – Runde (1 oder 2)
  votedAt        DateTime     @default(now())

  @@unique([sessionId, participantId, questionId, round]) // Nur eine Stimme pro Frage pro Runde
  @@index([sessionId, questionId, round])
  @@index([participantId, votedAt])
}

// Zuordnung Vote ↔ ausgewählte Antwortoptionen (n:m für MC-Mehrfachauswahl)
model VoteAnswer {
  id             String       @id @default(uuid())
  voteId         String
  vote           Vote         @relation(fields: [voteId], references: [id], onDelete: Cascade)
  answerOptionId String
  answerOption   AnswerOption @relation(fields: [answerOptionId], references: [id], onDelete: Cascade)

  @@unique([voteId, answerOptionId]) // Jede Option maximal einmal pro Vote
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum QuestionType {
  MULTIPLE_CHOICE
  SINGLE_CHOICE
  FREETEXT
  SURVEY
  RATING       // Story 1.2c: Bewertungsskala (1–5 oder 1–10)
}

enum Difficulty {
  EASY       // Multiplikator ×1
  MEDIUM     // Multiplikator ×2
  HARD       // Multiplikator ×3
}

enum SessionStatus {
  LOBBY          // Warten auf Teilnehmer
  QUESTION_OPEN  // Story 2.6: Nur Fragenstamm sichtbar (Lesephase)
  ACTIVE         // Antwortoptionen sichtbar, Countdown läuft
  PAUSED         // Zwischen Fragen
  RESULTS        // Ergebnisse werden angezeigt
  DISCUSSION     // Story 2.7: Peer Instruction – Diskussionsphase zwischen Runde 1 und 2
  FINISHED       // Session beendet
}

enum NicknameTheme {
  NOBEL_LAUREATES  // Nobelpreisträger (default, Hochschule)
  KINDERGARTEN     // Kita: Tiere & Farben (z.B. "Blauer Elefant")
  PRIMARY_SCHOOL   // Märchenfiguren (z.B. "Rotkäppchen")
  MIDDLE_SCHOOL    // Superhelden & Entdecker (z.B. "Kolumbus")
  HIGH_SCHOOL      // Wissenschaftler & Philosophen (z.B. "Kant")
}

enum TeamAssignment {
  AUTO    // Round-Robin: System verteilt Studenten gleichmäßig
  MANUAL  // Studenten wählen ihr Team selbst
}

enum SessionType {
  QUIZ       // Reguläres Quiz mit Fragen
  Q_AND_A    // Q&A-Modus (Story 8.1)
}

// ─── Bonus-Token (Story 4.6) ────────────────────────────────────────────────

// Individuelles Token für Top-Platzierungen, einlösbar per E-Mail beim Dozenten
model BonusToken {
  id            String      @id @default(uuid())
  token         String      @unique  // Kryptografisch sicher, z.B. "BNS-A3F7-K2M9"
  sessionId     String
  session       Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  nickname      String      // Snapshot des Pseudonyms zum Zeitpunkt der Generierung
  quizName      String      // Snapshot des Quiz-Namens
  totalScore    Int         // Erreichte Gesamtpunktzahl
  rank          Int         // Platzierung im Leaderboard (1-basiert)
  generatedAt   DateTime    @default(now())

  @@index([generatedAt])
}

// Story 4.8: Session-Bewertung durch Teilnehmende
model SessionFeedback {
  id                    String      @id @default(uuid())
  sessionId             String
  session               Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participantId         String
  participant           Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  overallRating         Int         // 1–5 Sterne
  questionQualityRating Int?        // 1–5 (optional)
  wouldRepeat           Boolean?    // "Sollen wir regelmäßig solche Quizze machen?"
  createdAt             DateTime    @default(now())

  @@unique([sessionId, participantId]) // Nur eine Bewertung pro Person pro Session
}

// ─── Q&A-Modus (Epic 8) ────────────────────────────────────────────────────

// Eine eingereichte Frage in einer Q&A-Session (Story 8.2–8.4)
model QaQuestion {
  id            String           @id @default(uuid())
  text          String           // Fragetext (max. 500 Zeichen, Markdown erlaubt)
  upvoteCount   Int              @default(0)
  status        QaQuestionStatus @default(ACTIVE)
  sessionId     String
  session       Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participantId String           // Story 8.2: Autor (für 3-Fragen-Limit pro Student)
  participant   Participant      @relation(fields: [participantId], references: [id], onDelete: Cascade)
  upvotes       QaUpvote[]       // Story 8.3: Einzelne Upvotes
  createdAt     DateTime         @default(now())

  @@index([sessionId, status, createdAt])
  @@index([sessionId, participantId])
}

// Vote-Tracking für Q&A-Fragen (Story 8.3): UP oder DOWN pro Teilnehmer
model QaUpvote {
  id            String         @id @default(uuid())
  qaQuestionId  String
  qaQuestion    QaQuestion     @relation(fields: [qaQuestionId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  direction     QaVoteDirection @default(UP)

  @@unique([qaQuestionId, participantId])
}

enum QaVoteDirection {
  UP
  DOWN
}

enum QaQuestionStatus {
  PENDING    // Wartet auf Moderation (bei moderationMode=true)
  ACTIVE     // Sichtbar und votebar
  PINNED     // Vom Dozenten hervorgehoben ("Wird gerade beantwortet")
  ARCHIVED   // Als beantwortet markiert
  DELETED    // Vom Dozenten entfernt
}

// ─── Admin Audit-Log (Epic 9, Story 9.2, 9.3) ────────────────────────────────

// Protokollierung von Admin-Aktionen (Löschen, Export); keine FK zu Session,
// damit Einträge nach Session-Löschung erhalten bleiben (Snapshot von code/id).
model AdminAuditLog {
  id               String           @id @default(uuid())
  action           AdminAuditAction
  sessionId        String           // Snapshot (Session kann danach gelöscht sein)
  sessionCode      String           // 6-stelliger Code (Snapshot)
  adminIdentifier  String?          // z. B. Token-ID oder "system" (aktuell: ein gemeinsamer Schlüssel)
  reason           String?          // Optionaler Löschgrund (Story 9.2)
  createdAt        DateTime         @default(now())

  @@index([createdAt])
  @@index([sessionCode, createdAt])
}

enum AdminAuditAction {
  SESSION_DELETE         // Story 9.2: Session inkl. Quiz-Daten gelöscht
  EXPORT_FOR_AUTHORITIES // Story 9.3: Auszug für Behörden exportiert
}

// ─── MOTD / Plattform-Kommunikation (Epic 10) ─────────────────────────────────

enum MotdStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model MotdTemplate {
  id           String   @id @default(uuid())
  name         String
  description  String?
  markdownDe   String   @default("") @db.Text
  markdownEn   String   @default("") @db.Text
  markdownFr   String   @default("") @db.Text
  markdownEs   String   @default("") @db.Text
  markdownIt   String   @default("") @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  motds        Motd[]
}

model Motd {
  id               String     @id @default(uuid())
  status           MotdStatus @default(DRAFT)
  priority         Int        @default(0)
  startsAt         DateTime
  endsAt           DateTime
  visibleInArchive Boolean    @default(false)
  contentVersion   Int        @default(1)
  templateId       String?
  template         MotdTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  locales          MotdLocale[]
  interactions     MotdInteractionCounter[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([status, startsAt, endsAt])
  @@index([visibleInArchive, endsAt])
}

model MotdLocale {
  id       String @id @default(uuid())
  motdId   String
  motd     Motd   @relation(fields: [motdId], references: [id], onDelete: Cascade)
  locale   String // de | en | fr | es | it (validiert via Zod)
  markdown String @db.Text

  @@unique([motdId, locale])
  @@index([motdId])
}

model MotdInteractionCounter {
  motdId         String
  contentVersion Int
  motd           Motd @relation(fields: [motdId], references: [id], onDelete: Cascade)
  ackCount       Int  @default(0)
  thumbUp        Int  @default(0)
  thumbDown      Int  @default(0)
  dismissClose   Int  @default(0)
  dismissSwipe   Int  @default(0)

  @@id([motdId, contentVersion])
  @@index([motdId])
}

enum MotdAuditAction {
  MOTD_CREATE
  MOTD_UPDATE
  MOTD_DELETE
  MOTD_PUBLISH
  MOTD_ARCHIVE_VISIBILITY
  MOTD_RESET_INTERACTION_STATS
  MOTD_TEMPLATE_CREATE
  MOTD_TEMPLATE_UPDATE
  MOTD_TEMPLATE_DELETE
}

model MotdAuditLog {
  id              String          @id @default(uuid())
  action          MotdAuditAction
  motdId          String
  adminIdentifier String?
  metadataJson    String?         @db.Text
  createdAt       DateTime        @default(now())

  @@index([motdId, createdAt])
  @@index([createdAt])
}
