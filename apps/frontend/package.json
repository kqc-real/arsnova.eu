{
  "name": "@arsnova/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "start:de": "ng serve --proxy-config proxy.conf.json",
    "start:en": "ng serve --configuration=development-en --proxy-config proxy.conf.json",
    "build": "ng build",
    "build:prod": "npm run build:localize",
    "serve:dist": "npx serve dist/browser -s",
    "build:localize": "ng run frontend:build:production && ng run frontend:server:production && node scripts/prerender-localized.mjs && node scripts/patch-prerender-noscript.mjs && node scripts/patch-sitemap-lastmod.mjs && node scripts/patch-pwa-manifest-per-locale.mjs && node scripts/regenerate-ngsw-localized.mjs && node -e \"require('fs').copyFileSync('static-root-index.html', 'dist/browser/index.html')\" && node scripts/check-motd-assets-postbuild.mjs",
    "serve:localize": "npx serve dist/browser -p 4200",
    "serve:localize:api": "node scripts/serve-localized-with-api.mjs",
    "lighthouse:serve": "npm run build:prod && npm run serve:dist",
    "check:viewport": "node scripts/check-viewport-320.mjs",
    "smoke:host-present-auth": "node scripts/check-host-present-auth-flow.mjs",
    "smoke:host-music": "node scripts/check-host-music-flow.mjs",
    "smoke:quiz-sync": "node scripts/check-quiz-sync-flow.mjs",
    "smoke:unified-session": "node scripts/check-unified-session-flow.mjs",
    "lighthouse:a11y": "node scripts/lighthouse-a11y.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "extract-i18n": "ng extract-i18n --output-path src/locale",
    "sync-i18n": "node scripts/sync-i18n-locales.mjs",
    "demo-quiz:locales": "node scripts/apply-demo-quiz-locale-strings.mjs",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "serve:ssr:frontend": "node dist/server/server.mjs"
  },
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@angular/ssr": "^21.2.0",
    "@arsnova/shared-types": "*",
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "dompurify": "^3.4.0",
    "express": "^5.1.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.32",
    "marked": "^17.0.3",
    "material-icons": "^1.13.14",
    "rxjs": "~7.8.0",
    "stopword": "^3.1.5",
    "tslib": "^2.7.0",
    "y-indexeddb": "^9.0.12",
    "y-websocket": "^3.0.0",
    "yjs": "^14.0.0-16"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.4.0-beta.4",
    "@analogjs/vitest-angular": "2.4.0-beta.4",
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/localize": "^21.2.0",
    "@types/express": "^5.0.1",
    "@types/katex": "^0.16.8",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.17.19",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.49.0",
    "postcss": "^8.4.0",
    "sharp-ico": "^0.1.5",
    "typescript": "~5.9.0",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  }
}
