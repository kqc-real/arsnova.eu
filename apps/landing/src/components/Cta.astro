---
import { GITHUB_URL, APP_URL_V3 } from '@/config/github';
const base = (typeof import.meta.env.BASE_URL === 'string' && import.meta.env.BASE_URL) || '/';
---

<section class="bg-slate-900 px-4 py-16 sm:px-6 sm:py-24" aria-labelledby="cta-heading">
  <div class="mx-auto max-w-3xl text-center">
    <h2 id="cta-heading" class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">Bereit für die erste Session?</h2>
    <p class="mt-4 text-lg text-slate-300">Kein Account für Lehrende, keine Installation für Teilnehmende. Session starten, Code oder QR teilen – Quiz, Abstimmung oder Q&amp;A.</p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a href={APP_URL_V3} class="inline-flex items-center gap-2 rounded-xl bg-brand-500 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-500/30 transition hover:bg-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-400 focus:ring-offset-2 focus:ring-offset-slate-900">
        <img src={`${base}favicon.svg`} alt="" class="h-5 w-5 shrink-0" width="20" height="20" />
        Zur App (Beta)
      </a>
    </div>
    <p class="mt-6">
      <a href={GITHUB_URL} class="text-sm text-slate-400 hover:text-white" target="_blank" rel="noopener noreferrer">Open Source auf GitHub</a>
    </p>
  </div>
</section>
