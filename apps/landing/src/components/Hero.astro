---
import { APP_URL_V3 } from '@/config/github';
const base = (typeof import.meta.env.BASE_URL === 'string' && import.meta.env.BASE_URL) || '/';
---

<section class="relative overflow-hidden bg-slate-900 px-4 py-20 sm:px-6 sm:py-28 lg:py-36" aria-labelledby="hero-heading">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-20%,rgba(14,165,233,0.25),transparent)]" aria-hidden="true" />
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-400/50 to-transparent" aria-hidden="true" />
  <div class="relative mx-auto max-w-5xl text-center">
    <p class="mb-4 text-sm font-semibold uppercase tracking-[0.24em] text-brand-400">Live-Quiz und Q&amp;A für die Lehre</p>
    <h1 id="hero-heading" class="font-display text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
      Interaktive Lehre ohne Accounts,<br />
      <span class="text-brand-400">ohne Abo, ohne Datensammeln.</span>
    </h1>
    <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-slate-300 sm:text-xl">
      arsnova.eu ist die datenschutzfreundliche Alternative für Lehrende, die Live-Quiz, Abstimmungen und Q&amp;A in einer Oberfläche bündelt. Kostenlos, Open Source, self-hostbar und in wenigen Minuten startklar.
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4" id="start">
      <a href={APP_URL_V3} class="inline-flex items-center gap-2 rounded-xl bg-brand-500 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-500/30 transition hover:bg-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-400 focus:ring-offset-2 focus:ring-offset-slate-900">
        <img src={`${base}favicon.svg`} alt="" class="h-5 w-5 shrink-0" width="20" height="20" />
        Jetzt live ausprobieren
      </a>
      <a href={`${base}#ablauf`} class="inline-flex items-center rounded-xl border border-slate-600 bg-slate-800/50 px-6 py-3.5 text-base font-semibold text-white backdrop-blur transition hover:border-slate-500 hover:bg-slate-800">
        So funktioniert’s
      </a>
    </div>
    <ul class="mt-12 grid gap-3 text-left text-sm text-slate-300 sm:grid-cols-2 xl:grid-cols-4" role="list">
      <li class="rounded-2xl border border-slate-700 bg-slate-800/60 px-4 py-3"><span class="font-semibold text-white">Ohne Account starten</span><br />Session per Code oder QR teilen</li>
      <li class="rounded-2xl border border-slate-700 bg-slate-800/60 px-4 py-3"><span class="font-semibold text-white">DSGVO-orientiert</span><br />Quiz-Inhalte local-first, Live-Daten temporär</li>
      <li class="rounded-2xl border border-slate-700 bg-slate-800/60 px-4 py-3"><span class="font-semibold text-white">Didaktisch stärker</span><br />Lesephase, Peer Instruction, Word Cloud, Q&amp;A</li>
      <li class="rounded-2xl border border-slate-700 bg-slate-800/60 px-4 py-3"><span class="font-semibold text-white">Open Source &amp; self-hostbar</span><br />Docker, Postgres, Redis und Admin-Audit</li>
    </ul>
  </div>
</section>
