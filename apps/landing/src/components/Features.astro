---
const features = [
  {
    title: 'Zielgruppenauswahl',
    description: 'Die Lehrperson wählt den Stil: Seriös (anonym, Fokus auf Inhalt) oder Spielerisch (Rangliste, Sounds, Anfeuerung). Von Kindergarten bis Oberstufe – ein Tool, viele Zielgruppen.',
    icon: 'toggle',
  },
  {
    title: 'Bonus-Option für die Besten',
    description: 'Top-Platzierte erhalten einen einlösbaren Code, den sie bei der Quizleitung einlösen können (z. B. für Bonuspunkte oder Anerkennung). Ohne autorisiertes Prüfungsinstrument – die Einlösung liegt bei dir.',
    icon: 'academic',
  },
  {
    title: 'Datenschutz zuerst',
    description: 'Quiz-Inhalte niemals dauerhaft auf dem Server. Local-First mit Yjs – 100 % DSGVO-konform, anonymer Modus, Stil Seriös verfügbar.',
    icon: 'shield',
  },
  {
    title: 'Zero-Account',
    description: 'Lehrpersonen starten sofort. Kein Login, keine Registrierung. 6-stelliger Code + QR – Teilnehmende sind in Sekunden dabei.',
    icon: 'bolt',
  },
  {
    title: 'Echtzeit-Kollaboration',
    description: 'Gemeinsam am Quiz arbeiten mit Yjs – mehrere Autor:innen gleichzeitig, Sync in Echtzeit. Markdown & KaTeX für MINT, Lesephase, Schwierigkeitsstufen.',
    icon: 'collab',
  },
  {
    title: 'Institutionelle Souveränität',
    description: 'Self-Hosted per Docker. Open Source, keine Abo-Kosten. WCAG 2.1 AA, Mobile-First, Dark-Mode.',
    icon: 'server',
  },
];
---

<section id="features" class="border-b border-slate-700 bg-slate-800/50 px-4 py-16 sm:px-6 sm:py-24" aria-labelledby="features-heading">
  <div class="mx-auto max-w-6xl">
    <h2 id="features-heading" class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">Warum arsnova.click?</h2>
    <p class="mt-3 max-w-2xl text-lg text-slate-400">Kostenlose, europäische Alternative zu Kahoot & Mentimeter – mit Zielgruppenauswahl, Bonus-Option und Zero-Knowledge. Ohne Kompromisse bei Datenschutz und Didaktik.</p>
    <ul class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {features.map((f) => (
        <li class="rounded-2xl border border-slate-600 bg-slate-800/80 p-6 transition hover:border-brand-500/50 hover:bg-slate-800">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-500/20 text-brand-400" aria-hidden="true">
            {f.icon === 'shield' && '🛡️'}
            {f.icon === 'bolt' && '⚡'}
            {f.icon === 'academic' && '🎓'}
            {f.icon === 'toggle' && '↔️'}
            {f.icon === 'collab' && '🤝'}
            {f.icon === 'server' && '📦'}
          </div>
          <h3 class="mt-4 font-display text-lg font-semibold text-white">{f.title}</h3>
          <p class="mt-2 text-slate-400">{f.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
