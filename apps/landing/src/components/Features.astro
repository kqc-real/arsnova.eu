<section id="features" class="border-b border-slate-700 bg-slate-800/50 px-4 py-16 sm:px-6 sm:py-24" aria-labelledby="features-heading">
  <div class="mx-auto max-w-6xl">
    <h2 id="features-heading" class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">Warum arsnova.eu?</h2>
    <p class="mt-3 max-w-2xl text-lg text-slate-400">Der Funktionsumfang aus dem Produkt-Backlog (Epics 0–6, 7, 8, 9): Live-Quiz, Q&A, Team- und Preset-Optionen, Word Cloud, Peer Instruction, Import/Export, KI-Workflow ohne Inhalts-Upload an uns, Mehrsprachen-UI und Admin für Betreiber – kostenlos und Open Source.</p>
    <ul class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {features.map((f) => (
        <li class="rounded-2xl border border-slate-600 bg-slate-800/80 p-6 transition hover:border-brand-500/50 hover:bg-slate-800">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-500/20 text-brand-400" aria-hidden="true">
            {f.icon === 'shield' && '🛡️'}
            {f.icon === 'bolt' && '⚡'}
            {f.icon === 'academic' && '🎓'}
            {f.icon === 'toggle' && '↔️'}
            {f.icon === 'collab' && '🤝'}
            {f.icon === 'server' && '📦'}
            {f.icon === 'ai' && '🤖'}
            {f.icon === 'single' && '🔗'}
            {f.icon === 'book' && '📚'}
            {f.icon === 'tools' && '🧭'}
            {f.icon === 'qa' && '💬'}
            {f.icon === 'trophy' && '🏆'}
            {f.icon === 'globe' && '🌍'}
          </div>
          <h3 class="mt-4 font-display text-lg font-semibold text-white">{f.title}</h3>
          <p class="mt-2 text-slate-400">{f.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
