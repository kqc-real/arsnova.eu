---
import { GITHUB_DOCS_URL } from '@/config/github';
const rows = [
  { area: 'Einstieg', feature: 'Eine Startseite, eine URL für Lehrende und Teilnehmende (erstellen oder mitmachen)', others: '❌', us: '✅' },
  { area: 'Kosten & Zugang', feature: 'Vollständig kostenlos & Open Source', others: '❌', us: '✅' },
  { area: 'Kosten & Zugang', feature: 'Kein Account für Lehrende nötig', others: '❌', us: '✅ Zero-Account' },
  { area: 'Datenschutz', feature: 'Quiz-Inhalte nicht dauerhaft auf dem Server', others: '❌', us: '✅ Local-First' },
  { area: 'Datenschutz', feature: 'DSGVO-orientiert + anonymer Modus', others: '🟡/✅', us: '✅' },
  { area: 'Einsatz', feature: 'Presets Seriös/Spielerisch, Team-Modus, Kita bis Uni', others: '❌/🟡', us: '✅' },
  { area: 'Session', feature: 'Lobby, Presenter/Beamer, Countdown, Live-Feedback', others: '✅', us: '✅' },
  { area: 'Fragetypen', feature: 'MC, SC, Freitext, Umfrage, Rating + Markdown/KaTeX', others: '🟡', us: '✅' },
  { area: 'Didaktik', feature: 'Lesephase, Peer Instruction (zweite Abstimmung)', others: '🟡', us: '✅' },
  { area: 'Didaktik', feature: 'Word Cloud live + Export', others: '🟡', us: '✅' },
  { area: 'Format', feature: 'Q&A mit Upvotes und Moderation', others: '✅ (oft Add-on)', us: '✅ integriert' },
  { area: 'Anreiz', feature: 'Leaderboard, Streak, Bonus-Code (Einlösung bei dir)', others: '🟡', us: '✅' },
  { area: 'Inhalte', feature: 'Quiz-Import/Export, Yjs Multi-Device-Sync', others: '🟡', us: '✅' },
  { area: 'KI-Quiz', feature: 'KI-unterstützter Import (Material bleibt extern)', others: '✅ (Cloud)', us: '✅ externes LLM + Zod, Zero-Knowledge' },
  { area: 'Sprachen', feature: 'Mehrsprachige Oberfläche (5 Locales)', others: '✅', us: '✅ de, en, fr, es, it' },
  { area: 'Technik', feature: 'Self-Hosted (Docker, Redis, Postgres)', others: '❌', us: '✅' },
  { area: 'Betrieb', feature: 'Admin: Inspektion, Löschung, Behördenexport + Audit', others: '❌', us: '✅ Self-Host' },
  { area: 'Barrierefreiheit', feature: 'Mobile-First, Dark/Light, WCAG 2.1 AA', others: '🟡', us: '🟡 AA-Ziel, Abschlussprüfung offen' },
];
---

<section id="vergleich" class="border-b border-slate-700 bg-slate-900 px-4 py-16 sm:px-6 sm:py-24" aria-labelledby="vergleich-heading">
  <div class="mx-auto max-w-6xl">
    <h2 id="vergleich-heading" class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">Vergleich mit Mentimeter, Kahoot & Slido</h2>
    <p class="mt-3 max-w-2xl text-lg text-slate-400">arsnova.eu bündelt Live-Quiz, Q&amp;A und Betriebsfunktionen für Self-Hosting – ohne Abo, ohne Lehrenden-Account, mit Local-First und KI-Workflow ohne Inhalts-Upload an die Plattform.</p>

    <div class="mt-10 min-w-0 overflow-hidden rounded-2xl border border-slate-600 bg-slate-800/80 shadow-lg">
      <div class="w-full max-w-full overflow-x-auto">
        <table class="w-full min-w-0 table-fixed divide-y divide-slate-600 text-left text-xs sm:text-sm" style="table-layout: fixed">
          <colgroup>
            <col style="width: 52%" />
            <col style="width: 24%" />
            <col style="width: 24%" />
          </colgroup>
          <thead>
            <tr class="bg-slate-800">
              <th scope="col" class="px-2 py-2 font-semibold text-white sm:px-4 sm:py-3">Bereich / Feature</th>
              <th scope="col" class="px-2 py-2 font-semibold text-slate-400 sm:px-4 sm:py-3">Mentimeter, Kahoot, Slido</th>
              <th scope="col" class="px-2 py-2 font-semibold text-brand-400 sm:px-4 sm:py-3">arsnova.eu</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-600">
            {rows.map((r) => (
              <tr class="hover:bg-slate-800/80">
                <td class="px-2 py-2 sm:px-4 sm:py-3">
                  <span class="font-medium text-white">{r.area}</span>
                  <span class="block text-slate-400">{r.feature}</span>
                </td>
                <td class="px-2 py-2 text-slate-400 sm:px-4 sm:py-3">{r.others}</td>
                <td class="px-2 py-2 font-medium text-brand-400 sm:px-4 sm:py-3">{r.us}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <p class="mt-4 text-sm text-slate-500">Vollständige Tabelle: <a href={GITHUB_DOCS_URL} class="text-brand-400 hover:text-brand-300 hover:underline" target="_blank" rel="noopener noreferrer">Docs im Repo</a></p>
  </div>
</section>
