# -----------------------------------------------------------------------------
# arsnova.eu - Lokale Umgebungsvariablen
# Kopiere diese Datei zu .env und passe die Werte bei Bedarf an.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Credentials / Secrets (zuerst)
# -----------------------------------------------------------------------------
POSTGRES_USER=arsnova_user
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=arsnova_v3_dev
DATABASE_URL="postgresql://arsnova_user:secretpassword@localhost:5432/arsnova_v3_dev?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="super-secret-local-dev-key"
ADMIN_SECRET="set-a-strong-admin-secret"

# -----------------------------------------------------------------------------
# Laufzeit / Netzwerk (lokal)
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
WS_PORT=3001
YJS_WS_PORT=3002
# In Dev optional; bei lokalem Reverse-Proxy ggf. auf 1 setzen:
# TRUST_PROXY_HOPS=1

# -----------------------------------------------------------------------------
# Admin-Konfiguration
# -----------------------------------------------------------------------------
ADMIN_SESSION_TTL_SECONDS=28800
ADMIN_LEGAL_HOLD_DEFAULT_DAYS=30

# -----------------------------------------------------------------------------
# Rate-Limiting (Dev-Defaults, Story 0.5 / Epic 10)
# -----------------------------------------------------------------------------
RATE_LIMIT_SESSION_CODE_ATTEMPTS=5
RATE_LIMIT_SESSION_CODE_WINDOW_MINUTES=5
RATE_LIMIT_SESSION_CODE_LOCKOUT_SECONDS=60
RATE_LIMIT_VOTE_REQUESTS_PER_SECOND=1
RATE_LIMIT_SESSION_CREATE_PER_HOUR=10

# Optional: Localhost-Bypass erzwingen (ohne Override in Nicht-Prod bereits aktiv)
# RATE_LIMIT_SESSION_CREATE_BYPASS_LOCALHOST=true
RATE_LIMIT_MOTD_GET_CURRENT_PER_MINUTE=600
# RATE_LIMIT_MOTD_GET_CURRENT_BYPASS_LOCALHOST=true
RATE_LIMIT_MOTD_LIST_ARCHIVE_PER_MINUTE=60
RATE_LIMIT_MOTD_RECORD_INTERACTION_PER_MINUTE=40