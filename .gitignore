# =============================================================================
# arsnova.eu – .gitignore
# =============================================================================

# ---------- Dependencies ----------
node_modules/

# ---------- Build output ----------
dist/
**/lighthouse-report.json
**/lighthouse-a11y-report.json
.astro/
out-tsc/
tmp/
.angular/
*.tsbuildinfo

# ---------- Environment / Secrets ----------
.env
.env.local
.env.production
.env.*.local

# ---------- IDE ----------
.idea/
.cursor/mcp.json
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------- Test & Coverage ----------
coverage/
.lighthouseci/
e2e/test-output/
artifacts/
scripts/load/artillery/.session.json
scripts/load/artillery/.runtime-state.json
scripts/load/artillery/.results-ready.flag
scripts/load/artillery/reports/

# ---------- Prisma ----------
prisma/*.db
prisma/*.db-journal

# ---------- Logs ----------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Nx ----------
.nx/cache
.nx/workspace-data

# ---------- Private teaching notes ----------
docs/_private-dozent/
